# Database
DATABASE_URL="postgresql://pms_user:pms_password@localhost:5432/pms_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-strong-random-secret-min-64-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-refresh-secret-min-64-chars"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV="development"
CORS_ORIGINS="http://localhost:5173,https://pmsfe2.vercel.app"
#
# Idle spin-down on free hosts (Render, etc.): periodic GET to this API’s **public** URL keeps traffic flowing.
# On Render, set HTTP_KEEPALIVE_ENABLED=true — RENDER_EXTERNAL_URL is injected for you (no need to duplicate it here).
HTTP_KEEPALIVE_ENABLED=false
# KEEPALIVE_PUBLIC_URL=https://your-api.onrender.com
# KEEPALIVE_PATH=/health
# KEEPALIVE_INTERVAL_MS=600000
# KEEPALIVE_BOOT_DELAY_MS=15000
# Public browser URL for ticket links in emails (no trailing slash)
APP_BASE_URL="http://localhost:5173"

# AI — Claude (Anthropic)
ANTHROPIC_API_KEY="your-anthropic-api-key"
CLAUDE_MODEL="claude-3-5-sonnet-20241022"

# AI — OpenAI
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o"

# Email — AWS SES or SMTP (credentials must match the provider you use)
# Gmail / personal Google: 2-Step Verification ON → use App password in SMTP_PASS (not your normal Gmail password).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-smtp-username@gmail.com"
SMTP_PASS="your-16-char-google-app-password-here"
EMAIL_FROM="Engineering Platform <noreply@yourcompany.com>"
#
# Troubleshooting ETIMEDOUT / command=CONN (TCP never connects from the API host — e.g. Render):
# - Confirm SMTP_HOST has no typo; Gmail is smtp.gmail.com · M365 often smtp.office365.com
# - Try SMTP_PORT=465 if 587 hangs (implicit SSL; the app sets secure=true for 465)
# - Optional slower networks: SMTP_CONNECTION_TIMEOUT_MS=60000  SMTP_GREETING_TIMEOUT_MS=60000
# - If IPv6 routing fails from your cloud: SMTP_FORCE_IPV4=true
# - SMTP_DEBUG=true for verbose SMTP wire logs on stdout
SMTP_CONNECTION_TIMEOUT_MS=45000
SMTP_GREETING_TIMEOUT_MS=45000
SMTP_SOCKET_TIMEOUT_MS=120000

# Google Sheets API
GOOGLE_SERVICE_ACCOUNT_JSON="./google-service-account.json"
GOOGLE_SHEET_ID="1-snIt7T2z3p2CW5eMpPZ8rR4mNk8gRX12FNbUD3fz28"

# Codemagen (Redmine JSON API) — HTTP Basic only. Required for mass extraction, sync-external, sync-legacy.
# Use a user with REST API permission. Prefer CODEMAGEN_*; REDMINE_* is still read for compatibility.
CODEMAGEN_BASE_URL="https://pms.codemagen.net"
CODEMAGEN_USERNAME=""
CODEMAGEN_PASSWORD=""
# REDMINE_USERNAME=""
# REDMINE_PASSWORD=""

# File Uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=50

# Feature Flags (SMTP delivery uses SMTP_* above whenever credentials are set)
ENABLE_AI_FEATURES=true
ENABLE_GOOGLE_SHEETS_SYNC=true
ENABLE_EMAIL_NOTIFICATIONS=true
